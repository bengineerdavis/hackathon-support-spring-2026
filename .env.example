SENTRY_AUTH_TOKEN=your_personal_auth_token_here
SENTRY_ORG_SLUG=your-org-slug
SENTRY_PROJECT_SLUG=your-project-slug
SENTRY_DSN=https://examplekey@o0.ingest.sentry.io/0
# Model key as understood by the llm library, e.g. ollama/llama3 or ollama/mistral
LLM_MODEL=ollama/llama3
# US region: https://us.sentry.io  |  EU region: https://de.sentry.io
SENTRY_BASE_URL=https://us.sentry.io
